  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \"react\";\nimport * as Icons from \"lucide-react\";\nimport {\n  Search,\n  Activity,\n  Flame,\n  ShieldAlert,\n  Sun,\n  Zap,\n  Sparkles,\n  MapPin,\n  Compass,\n  AlertCircle,\n  CheckCircle2,\n  XCircle,\n  ExternalLink,\n  Loader2,\n  HeartOff,\n  PhoneCall,\n  Award,\n  BookOpen,\n  Volume2\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\nimport { FirstAidGuide, EmergencyIssuePreset } from \"./types\";\nimport { PRIMARY_EMERGENCY_PRESETS } from \"./presets\";\nimport HospitalFinder from \"./components/HospitalFinder\";\nimport VoiceInput from \"./components/VoiceInput\";\nimport AudioPlayer from \"./components/AudioPlayer\";\n\n// Icon renderer helper to map preset icon strings to Lucide components\nfunction renderPresetIcon(name: string, className?: string) {\n  const IconComponent = (Icons as any)[name] || Activity;\n  return <IconComponent className={className} />;\n}\n\nexport default function App() {\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [activeGuide, setActiveGuide] = useState<FirstAidGuide | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [errorHeader, setErrorHeader] = useState<string | null>(null);\n  const [errorDetails, setErrorDetails] = useState<string[]>([]);\n  const [activeStepIndex, setActiveStepIndex] = useState<number>(0);\n  const [isCustomSymptom, setIsCustomSymptom] = useState(false);\n\n  // Load standard \"Burns\" guide on initial load so the screen doesn\'t start completely blank and gives instant user feedback\n  useEffect(() => {\n    const defaultPreset = PRIMARY_EMERGENCY_PRESETS.find(p => p.id === \"burns\");\n    if (defaultPreset) {\n      setActiveGuide(defaultPreset.guide);\n    }\n  }, []);\n\n  // Main search action handler\n  const handleFirstAidSearch = async (queryText: string) => {\n    const query = queryText.trim();\n    if (!query) return;\n\n    setLoading(true);\n    setErrorHeader(null);\n    setErrorDetails([]);\n    setIsCustomSymptom(false);\n    setActiveStepIndex(0);\n\n    // 1. Search in local high-fidelity presets first (instant loading!)\n    const loweredQuery = query.toLowerCase();\n    \n    // Check for direct or partial match\n    const foundPreset = PRIMARY_EMERGENCY_PRESETS.find(\n      (preset) =>\n        preset.id.includes(loweredQuery) ||\n        preset.label.toLowerCase().includes(loweredQuery) ||\n        loweredQuery.includes(preset.id) ||\n        loweredQuery.includes(preset.label.toLowerCase())\n    );\n\n    if (foundPreset) {\n      setActiveGuide(foundPreset.guide);\n      setLoading(false);\n      // Smooth scroll to the results card\n      setTimeout(() => {\n        document.getElementById(\"first-aid-results\")?.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n      }, 100);\n      return;\n    }\n\n    // 2. Query Gemini via Full-Stack backend for custom symptom queries\n    try {\n      const response = await fetch(\"/api/first-aid\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n        },\n        body: JSON.stringify({ symptom: query }),\n      });\n\n      const data = await response.json();\n\n      if (!response.ok) {\n        throw {\n          message: data.error || \"Failed to contact WHO first aid assistant.\",\n          steps: data.recoverySteps || [data.details || \"Is the server running? Check your terminal logs.\"]\n        };\n      }\n\n      setActiveGuide(data as FirstAidGuide);\n      setIsCustomSymptom(true);\n\n      // Smooth scroll to results\n      setTimeout(() => {\n        document.getElementById(\"first-aid-results\")?.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n      }, 100);\n\n    } catch (err: any) {\n      console.error(\"AI First Aid Fetch Error:\", err);\n      setErrorHeader(err.message || \"An unexpected connection issue occurred.\");\n      setErrorDetails(err.steps || [\"Verify internet connection.\", \"Please check details in the terminal console.\"]);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const onPresetClick = (preset: EmergencyIssuePreset) => {\n    setSearchQuery(\"\");\n    setErrorHeader(null);\n    setErrorDetails([]);\n    setIsCustomSymptom(false);\n    setActiveStepIndex(0);\n    setActiveGuide(preset.guide);\n    \n    // Smooth scroll to results\n    setTimeout(() => {\n      document.getElementById(\"first-aid-results\")?.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n    }, 100);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-50 flex flex-col antialiased\">\n      {/* Dynamic Header */}\n      <header className=\"bg-white border-b border-blue-50/80 sticky top-0 z-40 shadow-sm/30\">\n        <div className=\"max-w-6xl mx-auto px-4 py-4 flex items-center justify-between\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 rounded-2xl bg-gradient-to-tr from-blue-600 to-blue-500 flex items-center justify-center text-white shadow-md shadow-blue-200\">\n              <Activity className=\"w-5 h-5 animate-pulse\" />\n            </div>\n            <div>\n              <h1 className=\"text-xl font-bold font-display text-slate-800 tracking-tight flex items-center gap-2\">\n                Quick Aid\n                <span className=\"text-[10px] bg-blue-100 text-blue-800 font-semibold px-2 py-0.5 rounded-full uppercase tracking-wider\">\n                  Pro\n                </span>\n              </h1>\n              <p className=\"text-[11px] text-slate-400 font-medium font-sans\">\n                World Health Organization (WHO) Aligned Smart Assistant\n              </p>\n            </div>\n          </div>\n\n          <div className=\"flex items-center gap-3\">\n            <span className=\"hidden md:inline-flex items-center gap-1.5 text-xs text-sky-700 bg-sky-50 px-3 py-1.5 rounded-xl font-semibold\">\n              <Award className=\"w-3.5 h-3.5\" /> Emergency Preparedness Active\n            </span>\n            <a\n              href=\"#hospital-finder-section\"\n              className=\"text-xs bg-blue-50 text-blue-600 hover:bg-blue-100 font-semibold px-3 py-2 rounded-xl transition flex items-center gap-1\"\n            >\n              <MapPin className=\"w-3.5 h-3.5\" />\n              <span>Hospital Locator</span>\n            </a>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <main className=\"flex-1 max-w-6xl w-full mx-auto px-4 py-8 flex flex-col gap-8\">\n        \n        {/* Banner Announcement / Reassurance Hero */}\n        <section className=\"bg-gradient-to-br from-blue-700 to-indigo-800 rounded-3xl p-6 md:p-10 text-white shadow-xl shadow-blue-100 border border-blue-800 relative overflow-hidden\">\n          {/* Subtle decoration vectors */}\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-3xl pointer-events-none\"></div>\n          <div className=\"absolute bottom-0 left-1/4 w-80 h-80 bg-blue-500/10 rounded-full blur-2xl pointer-events-none\"></div>\n\n          <div className=\"max-w-2xl relative z-10\">\n            <span className=\"text-xs font-bold uppercase tracking-widest text-blue-200 bg-blue-600/45 border border-blue-400/23 px-3 py-1 rounded-full\">\n              WHO Evidence-Based First Aid Guidelines\n            </span>\n            <h2 className=\"text-3xl md:text-4xl font-extrabold font-display leading-tight mt-4 tracking-tight\">\n              Instant First Aid, Spoken Out Loud.\n            </h2>\n            <p className=\"text-blue-100/90 text-sm md:text-base mt-3 leading-relaxed\">\n              Enter any health crisis or symptom. Our AI searches certified WHO standards to deliver immediate voice-guided treatment routines, keeping you composed while dispatch is on the way.\n            </p>\n          </div>\n        </section>\n\n        {/* Symptoms Entry Section (Text Search & Advanced Voice Mic) */}\n        <section className=\"bg-white rounded-3xl border border-blue-50 p-6 md:p-8 shadow-sm flex flex-col gap-6\">\n          <div>\n            <h3 className=\"text-lg font-bold text-slate-800 leading-none\">Describe the Health Emergency</h3>\n            <p className=\"text-xs text-slate-500 mt-1.5 flex items-center gap-1\">\n              <BookOpen className=\"w-3.5 h-3.5 text-blue-500\" />\n              WHO Standard: Direct step explanations should be triggered quickly to handle active trauma.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-start\">\n            {/* Input Form Column */}\n            <form\n              onSubmit={(e) => {\n                e.preventDefault();\n                handleFirstAidSearch(searchQuery);\n              }}\n              className=\"lg:col-span-7 flex flex-col gap-3\"\n            >\n              <div className=\"relative flex items-center\">\n                <input\n                  type=\"text\"\n                  placeholder=\"e.g., thermal arm burn, choking, snake bite, severe leg bleeding...\"\n                  value={searchQuery}\n                  onChange={(e) => setSearchQuery(e.target.value)}\n                  className=\"w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white text-slate-800 font-medium rounded-2xl pl-12 pr-4 py-4 text-sm md:text-base outline-none transition-all placeholder:text-slate-400\"\n                />\n                <Search className=\"absolute left-4 w-5 h-5 text-slate-400 pointer-events-none\" />\n              </div>\n\n              <div className=\"flex flex-col sm:flex-row gap-3\">\n                <button\n                  type=\"submit\"\n                  disabled={loading || !searchQuery.trim()}\n                  className=\"flex-1 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-200 disabled:text-slate-400 font-semibold text-white px-6 py-4 rounded-2xl shadow-md shadow-blue-100 transition flex items-center justify-center gap-2\"\n                >\n                  {loading ? (\n                    <Loader2 className=\"w-5 h-5 animate-spin\" />\n                  ) : (\n                    <Sparkles className=\"w-5 h-5\" />\n                  )}\n                  <span>Evaluate Symptoms with WHO Guidelines</span>\n                </button>\n                {searchQuery && (\n                  <button\n                    type=\"button\"\n                    onClick={() => setSearchQuery(\"\")}\n                    className=\"bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-semibold px-4 py-4 rounded-2xl transition\"\n                  >\n                    Clear Input\n                  </button>\n                )}\n              </div>\n            </form>\n\n            <div className=\"hidden lg:flex items-center justify-center lg:col-span-1 py-4\">\n              <span className=\"w-px h-16 bg-slate-200/80\"></span>\n            </div>\n\n            {/* Voice Input Integration */}\n            <div className=\"lg:col-span-4\">\n              <VoiceInput\n                onTranscriptionComplete={(text) => {\n                  setSearchQuery(text);\n                  handleFirstAidSearch(text);\n                }}\n                isLoading={loading}\n              />\n            </div>\n          </div>\n\n          {/* Quick preset buttons */}\n          <div className=\"border-t border-slate-15 pb-2 pt-6\">\n            <span className=\"text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-3.5 px-1\">\n              Select standard WHO emergency tutorials for instant load (Zero Latency)\n            </span>\n            <div className=\"grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3\">\n              {PRIMARY_EMERGENCY_PRESETS.map((preset) => (\n                <button\n                  key={preset.id}\n                  onClick={() => onPresetClick(preset)}\n                  className=\"flex flex-col items-center justify-center p-3 rounded-2xl border border-slate-50 bg-slate-50/50 hover:bg-blue-50/70 hover:border-blue-400/35 hover:shadow-xs transition-all duration-200 text-center\"\n                >\n                  <div className=\"w-10 h-10 rounded-full bg-white border border-slate-100 flex items-center justify-center text-blue-600 shadow-xs mb-2 group-hover:scale-105 transition\">\n                    {renderPresetIcon(preset.icon, \"w-5 h-5 text-blue-600\")}\n                  </div>\n                  <span className=\"text-xs font-bold text-slate-700\">{preset.label}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n        </section>\n\n        {/* Global Loading Spinner for Custom Symptoms Assessment */}\n        <AnimatePresence>\n          {loading && (\n            <motion.div\n              initial={{ opacity: 0, scale: 0.95 }}\n              animate={{ opacity: 1, scale: 1 }}\n              exit={{ opacity: 0, scale: 0.95 }}\n              className=\"bg-white rounded-3xl border border-blue-50 p-12 text-center shadow-sm flex flex-col items-center justify-center gap-4\"\n            >\n              <div className=\"w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center text-blue-600 animate-spin\">\n                <Loader2 className=\"w-8 h-8\" />\n              </div>\n              <div>\n                <h4 className=\"font-bold text-lg text-slate-800\">Reviewing Emergency Symptoms with Gemini AI</h4>\n                <p className=\"text-xs text-slate-500 mt-1 max-w-sm mx-auto leading-relaxed\">\n                  Strictly filtering results using WHO First Aid guidelines. Please stay calm. Para-medical checks are executing.\n                </p>\n              </div>\n              <div className=\"flex flex-col gap-1 text-[11px] text-slate-400 font-mono mt-2 bg-slate-50 px-4 py-2.5 rounded-xl border border-slate-100\">\n                <span>[LOG] Initializing Gemini 3.5-Flash model...</span>\n                <span>[LOG] Loading WHO guideline corpus alignments...</span>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n        {/* Gemini API Missing / Secret keys Configuration Error Fallback */}\n        <AnimatePresence>\n          {errorHeader && (\n            <motion.div\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0 }}\n              className=\"bg-white rounded-3xl border border-amber-200 p-6 md:p-8 shadow-sm\"\n            >\n              <div className=\"flex gap-4\">\n                <div className=\"w-12 h-12 rounded-full bg-amber-50 text-amber-600 flex items-center justify-center shrink-0\">\n                  <AlertCircle className=\"w-6 h-6\" />\n                </div>\n                <div>\n                  <h3 className=\"text-lg font-bold text-slate-800 font-display leading-tight\">{errorHeader}</h3>\n                  <div className=\"text-sm text-slate-600 mt-2 leading-relaxed\">\n                    <p className=\"font-semibold\">Steps to resolve this locally or on AI Studio:</p>\n                    <ul className=\"list-disc list-inside mt-2 space-y-1 text-slate-500 text-xs\">\n                      {errorDetails.map((step, idx) => (\n                        <li key={idx} className=\"leading-relaxed\">{step}</li>\n                      ))}\n                    </ul>\n                  </div>\n                  \n                  {/* Urgent Recommendation */}\n                  <div className=\"mt-4 p-4 bg-amber-50/50 border border-amber-100 rounded-2xl\">\n                    <p className=\"text-xs text-amber-900 font-semibold leading-relaxed\">\n                      \360\237\222\241 Emergency Workaround: You can click any of our Preloaded Common Issues presets below the search bar! They are fully loaded from certified standard WHO manuals and work instantly without requiring a Gemini API key.\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n        {/* First Aid Instructions Output Guide Display */}\n        <AnimatePresence>\n          {activeGuide && !loading && (\n            <motion.section\n              key={activeGuide.title}\n              id=\"first-aid-results\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              transition={{ duration: 0.35 }}\n              className=\"bg-white rounded-3xl border border-blue-50 shadow-sm p-6 md:p-8 flex flex-col gap-6\"\n            >\n              {/* Output Header */}\n              <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-blue-50/80 pb-6\">\n                <div>\n                  <span className=\"text-xs bg-emerald-50 text-emerald-700 font-bold px-3 py-1.5 rounded-full border border-emerald-200/50\">\n                    WHO Guideline Corroborated\n                  </span>\n                  \n                  <h2 className=\"text-2xl font-extrabold text-slate-800 font-display mt-3 flex items-center gap-2\">\n                    {activeGuide.title}\n                  </h2>\n                  <p className=\"text-xs text-slate-400 mt-1 flex items-center gap-1 font-mono\">\n                    <Award className=\"w-3.5 h-3.5 text-blue-500 shrink-0\" />\n                    Source: {activeGuide.whoRef}\n                  </p>\n                </div>\n\n                <div className=\"flex items-center gap-3 shrink-0\">\n                  {/* Severity Badges */}\n                  <div className=\"flex flex-col items-end\">\n                    <span className=\"text-[10px] text-slate-450 uppercase font-bold tracking-wider\">Severity Level</span>\n                    <span\n                      className={`text-xs font-extrabold px-3.5 py-1.5 rounded-full mt-1.5 uppercase tracking-wide border ${\n                        activeGuide.severity === \"Critical\"\n                          ? \"bg-rose-50 text-rose-700 border-rose-200 animate-pulse\"\n                          : activeGuide.severity === \"Moderate\"\n                          ? \"bg-amber-50 text-amber-700 border-amber-200\"\n                          : \"bg-emerald-50 text-emerald-700 border-emerald-200\"\n                      }`}\n                    >\n                      {activeGuide.severity}\n                    </span>\n                  </div>\n                </div>\n              </div>\n\n              {/* Speech Synthesis Utility Card */}\n              <AudioPlayer\n                guide={activeGuide}\n                activeStepIndex={activeStepIndex}\n                setActiveStepIndex={setActiveStepIndex}\n              />\n\n              {/* High-Stress Emergency Banner */}\n              {(activeGuide.emergencyContactRequired || activeGuide.severity === \"Critical\") && (\n                <div className=\"bg-rose-50 border border-rose-200/60 rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4\">\n                  <div className=\"flex gap-3 items-start text-rose-900\">\n                    <PhoneCall className=\"w-6 h-6 text-rose-600 shrink-0 mt-0.5 animate-bounce\" />\n                    <div>\n                      <h4 className=\"font-extrabold text-rose-800 text-sm md:text-base\">Life-Threatening Emergency Assessed</h4>\n                      <p className=\"text-xs text-rose-700 mt-1 max-w-xl leading-relaxed\">\n                        This scenario can degenerate rapidly. Instruct someone nearby to call emergency paramedics immediately. Keep call connected on speakerphone.\n                      </p>\n                    </div>\n                  </div>\n                  <a\n                    href=\"tel:911\"\n                    className=\"bg-rose-600 hover:bg-rose-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg shadow-rose-200 transition text-sm flex items-center gap-2 whitespace-nowrap\"\n                  >\n                    <PhoneCall className=\"w-4 h-4 fill-white\" />\n                    <span>Dial Emergency (911)</span>\n                  </a>\n                </div>\n              )}\n\n              {/* Dynamic steps display */}\n              <div className=\"list-steps-grid\">\n                <span className=\"text-xs font-semibold text-slate-400 uppercase tracking-widest block mb-4 px-1\">\n                  Step-by-Step Emergency Operations\n                </span>\n                \n                <div className=\"grid grid-cols-1 md:grid-cols-1 gap-3.5\">\n                  {activeGuide.steps.map((stepStr, idx) => {\n                    const isStepActive = idx === activeStepIndex;\n                    return (\n                      <button\n                        key={idx}\n                        onClick={() => {\n                          setActiveStepIndex(idx);\n                        }}\n                        className={`w-full text-left p-4 md:p-5 rounded-2xl border transition-all duration-200 flex items-start gap-4 ${\n                          isStepActive\n                            ? \"border-blue-500 bg-blue-50/40 shadow-sm\"\n                            : \"border-slate-100 bg-white hover:bg-slate-50/80 hover:border-slate-200\"\n                        }`}\n                      >\n                        <span\n                          className={`w-7 h-7 rounded-full shrink-0 flex items-center justify-center font-bold text-xs ${\n                            isStepActive\n                              ? \"bg-blue-600 text-white\"\n                              : \"bg-slate-100 text-slate-600\"\n                          }`}\n                        >\n                          {idx + 1}\n                        </span>\n                        <div>\n                          <p\n                            className={`text-sm md:text-base font-semibold leading-relaxed ${\n                              isStepActive ? \"text-slate-900\" : \"text-slate-700\"\n                            }`}\n                          >\n                            {stepStr}\n                          </p>\n                          {isStepActive && (\n                            <span className=\"text-[10px] text-blue-600 font-bold block mt-2 animate-pulse flex items-center gap-1 uppercase tracking-wider\">\n                              <Volume2 className=\"w-3.0 h-3.0 shrink-0 inline\" /> Speaking This Step\n                            </span>\n                          )}\n                        </div>\n                      </button>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Parallel DOs & DON\'Ts Column Panels */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 mt-4\">\n                {/* DO\'s */}\n                <div className=\"bg-emerald-50/40 border border-emerald-100/60 rounded-3xl p-5 md:p-6 flex flex-col gap-4\">\n                  <h3 className=\"font-bold text-emerald-800 text-sm md:text-base flex items-center gap-2\">\n                    <CheckCircle2 className=\"w-5 h-5 text-emerald-600 shrink-0\" />\n                    Critical Recommendations (DOs)\n                  </h3>\n                  <ul className=\"flex flex-col gap-3\">\n                    {activeGuide.dos.map((doStr, idx) => (\n                      <li key={idx} className=\"flex gap-2 text-xs md:text-sm text-emerald-900 leading-relaxed font-semibold\">\n                        <span className=\"text-emerald-500 shrink-0\">\342\234\223</span>\n                        <span>{doStr}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n\n                {/* DONT\'s */}\n                <div className=\"bg-rose-50/30 border border-rose-100/40 rounded-3xl p-5 md:p-6 flex flex-col gap-4\">\n                  <h3 className=\"font-bold text-rose-800 text-sm md:text-base flex items-center gap-2\">\n                    <XCircle className=\"w-5 h-5 text-rose-600 shrink-0\" />\n                    Strict Prohibitions (DON\'Ts)\n                  </h3>\n                  <ul className=\"flex flex-col gap-3\">\n                    {activeGuide.donts.map((dontStr, idx) => (\n                      <li key={idx} className=\"flex gap-2 text-xs md:text-sm text-rose-900/90 leading-relaxed font-semibold\">\n                        <span className=\"text-rose-500 font-bold shrink-0\">\342\234\226</span>\n                        <span>{dontStr}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n              </div>\n\n              {/* Dynamic Assessment Disclaimer Tag */}\n              {isCustomSymptom && (\n                <div className=\"p-3 bg-blue-50/40 border border-blue-100 rounded-xl mt-2 flex items-center justify-between text-xs text-blue-700 font-medium\">\n                  <span>\342\234\250 Instantly compiled using Gemini 3.5-flash text engine aligning with WHO specifications</span>\n                  <Award className=\"w-4 h-4 text-blue-500 shrink-0 hidden md:block\" />\n                </div>\n              )}\n            </motion.section>\n          )}\n        </AnimatePresence>\n\n        {/* GPS Hospital Tracker Map */}\n        <section className=\"section-map\">\n          <HospitalFinder />\n        </section>\n\n      </main>\n\n      {/* Modern Minimal Footer */}\n      <footer className=\"bg-slate-900 text-slate-300 mt-16 border-t border-slate-800\">\n        <div className=\"max-w-6xl mx-auto px-4 py-8 flex flex-col md:flex-row items-center justify-between gap-6\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-8 h-8 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold\">\n              +\n            </div>\n            <div>\n              <p className=\"font-bold font-display text-sm tracking-tight text-white\">Quick Aid Assistant</p>\n              <p className=\"text-[11px] text-slate-400 mt-0.5\">Tested for local and deploy execution.</p>\n            </div>\n          </div>\n          <p className=\"text-center md:text-right text-[11px] text-slate-400 max-w-md leading-relaxed select-none\">\n            Emergency Standard Protection Notice: Quick Aid is an assistive visual and synthesized aid curated from World Health Organization guidelines. This application does not replace professional on-scene emergency diagnosis or critical dispatch calling.\n          </p>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }
