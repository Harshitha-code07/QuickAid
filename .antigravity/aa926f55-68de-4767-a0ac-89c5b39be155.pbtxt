          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Lean the choking person forward so the dislodged object falls out of the mouth, not back down.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Encourage coughing if the person can breathe or speak.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Call emergency services immediately if the airway remains blocked after 1 minute.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT perform blind finger sweeps inside the mouth as you may push the object deeper.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT perform abdominal thrusts on pregnant women or infants (use chest thrusts instead).\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT hit them on the back while they are in an upright standing position.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: true"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"severe-bleeding\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Bleeding\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"HeartOff\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Rapid, continuous, or spurting blood loss from a wound\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Severe Bleeding\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Critical\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO Trauma Care Guidelines & International Wound Standards\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Safety Check: Wear gloves if available to prevent cross-contamination.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Apply Direct Pressure: Press firmly on the wound with a clean sterile cloth or your bare hands.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Maintain Pressure: Hold continuous, firm pressure with no breaks for at least 5-10 minutes.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Elevate: If possible, elevate the bleeding limb above the level of the heart.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Apply Bandage: Wrap a clean bandage snugly over the dressing. Do not cut off circulation.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Secondary Dressing: If blood seeps through, place another pad directly over it. Do NOT remove first pad.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Keep the patient lying down and warm to prevent shock.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Keep pressure firm and uninterrupted until medical help arrives.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Use sterile or cleanest available fabrics first.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT remove blood-soaked dressings, as this disrupts the forming clot.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT apply a tight tourniquet unless trained and pressure has completely failed.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT wash or clean a wound that is actively bleeding heavily.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: true"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"burns\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Burns\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"Flame\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Thermal, electrical, or chemical skin tissue damage\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Thermal Burns\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Moderate\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO Burn Management & Care Guidelines\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Cool Immediate: Flush the burned area under cool running water for 15-20 minutes.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Remove Constrictions: Gently remove rings, jewelry, or tight clothing before swelling starts.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT peel: If clothing is stuck to the burn, leave it. Wet around it instead.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Cover loosely: Cover the cooled burn loosely with clean plastic wrap or a sterile non-stick bandage.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Pain Management: Keep the victim hydrated and seated in a comfortable cool state.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Use ONLY cool, clean running water (15\302\260C to 25\302\260C).\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Cover the burn to protect from dirt and bacterial infection.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Seek medical care if burn is larger than the victim\'s palm.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT apply ice, ice water, butter, oils, toothpaste, or traditional home remedies.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT pop blisters. Intact skin protects against severe infection.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT use fluffy cotton dressings that can lint and stick to the wound.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: false"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"fracture\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Fracture\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"ShieldAlert\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Broken, cracked, or deformed bone structure\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Fractures & Joint Injuries\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Moderate\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO Essential Trauma Care Guidelines\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Immobilize: Keep the injured limb completely still. Do not try to move the person.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Support Splint: Protect the joint above and below the break using folded cardboard or wood.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Secure Splint: Tie splints securely with cloth bands. Do not tie directly over the fracture point.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Elevate & Cold: Apply wrapped ice packs to reduce swelling (wrapped in cloth, not bare skin).\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Control Bleeding: If bone is protruding (open fracture), apply pressure around bone, do NOT press bone.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Treat Shock: Keep them warm, calm, and resting flat.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Wrap ice packs in a clean cloth. Never apply cold source directly to skin.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Support the bone securely in the position you found it.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Check circulation below the splint periodically (pulse or warmth).\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT try to realign, straighten, or pop a bone back into place.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT let the person walk or bear weight if a lower limb fracture is suspected.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT give anything to eat or drink in case emergency surgery is needed.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: true"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"heart-attack\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Heart Attack\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"HeartPulse\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Crushing chest pain, shortness of breath, left-arm discomfort\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Suspected Heart Attack\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Critical\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO Cardiovascular Medical Emergency Guidelines\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Call Help First: Call local emergency services (911) immediately. Do not wait.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Rest Comfortable: Have them sit on the floor in a \'W-position\' with back supported and knees bent.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Loosen Clothes: Loosen tight collars, ties, belts, or chest pieces.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Provide Aspirin: If fully conscious and not allergic, let them chew 300mg of standard Aspirin.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Monitor Vitals: Keep speaking to them and monitor breathing. Record details for paramedics.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Be Ready for CPR: If they stop breathing, begin high-quality chest compressions immediately.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Stay with the person and keep them calm. Anxiety increases workload on the heart.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Make sure to keep them physically resting. Do NOT walk them.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Gather all current medications they take to show emergency staff.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT let them drive themselves to the hospital.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT give aspirin if they are allergic, or have been told never to take it.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT ignore symptoms like severe jaw, back, or neck pain combined with sweating.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: true"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"heatstroke\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Heat Stroke\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"Sun\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Very high body temp, confusion, skin dry or heavy sweating\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Heat Stroke & Exhaustion\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Critical\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO Environmental Health & Heatwave Safety Standards\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Relocate: Move the person into a cool, air-conditioned, or well-shaded place.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Active Cooling: Remove excess clothing. Spray or sponge them with cool water.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Maximize Airflow: Fan them vigorously to speed up evaporation cooling.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Ice Pointing: Apply cool wet towels or ice packs to neck, armpits, and groin.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Rehydrate Sips: If fully conscious and swallowing well, give small sips of cool water.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Continuous Vitals: Monitor closely. Heat stroke is fatal if core temperature is unchecked.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Fanning and wetting skin is the fastest surface cooling methodology.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Keep the person recumbent with feet slightly raised.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT give paracetamol or aspirin; they will not work for environmental heat fever.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT give fluids to someone who is confused, drowsy, or vomiting.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT plunge them into an ice bath unsupervised due to risk of shock.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      emergencyContactRequired: true"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \"poisoning\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    label: \"Poisoning\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    icon: \"Sparkles\", // represents chemical or substance hazard"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Ingestion, inhalation, or skin contact with toxic substances\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    guide: {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      title: \"First Aid for Poisoning & Toxic Exposure\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      severity: \"Critical\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      whoRef: \"WHO International Programme on Chemical Safety Guidelines\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      steps: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Identify Source: Safely secure the container, label, or substance to identify chemical name.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Dermal/Ocular: If skin/eyes are contacted, rinse continuously with running water for 15 minutes.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Airways/Gas: If inhaled, move them immediately to fresh open air.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Mouth Sweep: If ingested, wash the mouth carefully. Spit out remaining substances.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Call Poison Center: Phone emergency toxic services or hospital immediately.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Positioning: If they are drowsy or vomit, place them in the \'Recovery Position\' on their side.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dos: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Save vomiting specimens in a container if poison source is unknown.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Keep the air flowing and loosen tight clothing.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      donts: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT induce vomiting unless explicitly directed by poison expert; acids can re-burn the throat.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"Do NOT give charcoal, milk, or home remedies without specialist instructions.\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
